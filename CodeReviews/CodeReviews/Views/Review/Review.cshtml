@model Review
@{
    ViewData["Title"] = "Submit a Review";
}
<div class="text-center">
    <h1>Submit a Code Review</h1>
</div>
<form asp-action="Review" method="post">
    <div class="mb-3">
        <label class="form-label">Reviewer Name</label>
        <input asp-for="Reviewer.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Submission Code URL</label>
        <input asp-for="Submission.CodeUrl" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Review Link</label>
        <input asp-for="ReviewUrl" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Comments</label>
        <textarea asp-for="Comments" class="form-control" rows="5"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Submit Review</button>
</form>
<div class="mt-3">
    <a asp-action="List">Back to Reviews</a>
</div>
