@model CodeReviews.Models.ReadinessChecklistViewModel

@{
    ViewData["Title"] = "Code Readiness Checker";
}

<div class="container mt-4">
    <h2>Code Review Readiness Checker</h2>
    <p class="lead">Complete this checklist to see if your code is ready for review.</p>

    <form asp-action="Index" method="post">
        <div class="card mb-3">
            <div class="card-header bg-danger text-white">
                <h5>Critical - Build & Run</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="ProjectBuilds" />
                    <label class="form-check-label" asp-for="ProjectBuilds">
                        My project builds without errors
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="AppRuns" />
                    <label class="form-check-label" asp-for="AppRuns">
                        My app runs without crashing
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="NoRuntimeErrors" />
                    <label class="form-check-label" asp-for="NoRuntimeErrors">
                        Main pages/features work without runtime errors
                    </label>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-warning">
                <h5>Important - Code Quality</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="CodeIsClean" />
                    <label class="form-check-label" asp-for="CodeIsClean">
                        My code is clean (no debug statements, unused code, etc.)
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="FollowsNamingConventions" />
                    <label class="form-check-label" asp-for="FollowsNamingConventions">
                        I follow C# naming conventions
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="HasErrorHandling" />
                    <label class="form-check-label" asp-for="HasErrorHandling">
                        I have proper error handling
                    </label>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5>Documentation</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="HasReadme" />
                    <label class="form-check-label" asp-for="HasReadme">
                        I have a README with project description and setup instructions
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="HasComments" />
                    <label class="form-check-label" asp-for="HasComments">
                        Complex code sections have explanatory comments
                    </label>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h5>Nice to Have - Testing</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="HasTests" />
                    <label class="form-check-label" asp-for="HasTests">
                        I have unit tests
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="TestsPass" />
                    <label class="form-check-label" asp-for="TestsPass">
                        All tests pass
                    </label>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">
                <h5>Repository</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="CommitsHaveMessages" />
                    <label class="form-check-label" asp-for="CommitsHaveMessages">
                        My commits have meaningful messages
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="NoSensitiveData" />
                    <label class="form-check-label" asp-for="NoSensitiveData">
                        No sensitive data (passwords, API keys) in repository
                    </label>
                </div>
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary btn-lg">Check My Readiness</button>
        </div>
    </form>
</div>
